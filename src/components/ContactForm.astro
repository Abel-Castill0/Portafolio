<form class="contact-form" action="https://api.web3forms.com/submit" method="POST" data-reveal>
  <input type="hidden" name="subject" value="Nuevo contacto desde el portafolio" />
  <input type="hidden" name="from_name" value="Portafolio Abel Castillo" />
  <input type="hidden" name="access_key" value="3c95ccb6-8459-4e36-8a7e-656620650f78" />
  <div class="form-field">
    <label for="contact-name">Nombre</label>
    <input id="contact-name" name="name" type="text" autocomplete="name" maxlength="100" required placeholder="Tu nombre" />
  </div>
  <div class="form-field">
    <label for="contact-email">Correo</label>
    <input id="contact-email" name="email" type="email" autocomplete="email" maxlength="254" required placeholder="tu@correo.com" />
  </div>
  <div class="form-field form-field-wide">
    <label for="contact-message">Proyecto</label>
    <textarea id="contact-message" name="message" minlength="20" maxlength="2000" required placeholder="Problema, alcance y objetivo"></textarea>
  </div>
  <div class="form-actions form-field-wide">
    <p class="form-status" role="status" aria-live="polite">Al enviar, Web3Forms procesará el mensaje de forma segura.</p>
    <button type="submit"><span class="button-label">Enviar propuesta</span> <span aria-hidden="true">↗</span></button>
  </div>
</form>

<script>
  const form = document.querySelector<HTMLFormElement>(".contact-form");

  if (form) {
    const submitButton = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const buttonLabel = form.querySelector<HTMLElement>(".button-label");
    const status = form.querySelector<HTMLElement>(".form-status");
    const controller = new AbortController();

    const setState = (message: string, state: "idle" | "loading" | "success" | "error") => {
      if (!submitButton || !buttonLabel || !status) return;
      status.textContent = message;
      status.dataset.state = state;
      submitButton.disabled = state === "loading";
      submitButton.setAttribute("aria-busy", String(state === "loading"));
      buttonLabel.textContent = state === "loading" ? "Enviando..." : state === "success" ? "Mensaje enviado" : "Enviar propuesta";
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!form.reportValidity() || submitButton?.disabled) return;

      const accessKey = form.elements.namedItem("access_key") as HTMLInputElement | null;
      if (!accessKey?.value.trim()) {
        setState("El formulario aún no está configurado. Escríbeme por correo.", "error");
        return;
      }

      setState("Enviando...", "loading");

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
          signal: controller.signal,
        });
        const result = await response.json() as { success?: boolean; message?: string };

        if (!response.ok || !result.success) {
          throw new Error(result.message || "No se pudo enviar el mensaje.");
        }

        form.reset();
        setState("Mensaje enviado exitosamente.", "success");
      } catch {
        setState("No se pudo enviar. Intenta nuevamente o usa el correo directo.", "error");
      }
    }, { signal: controller.signal });

    const cleanup = () => controller.abort();
    addEventListener("pagehide", cleanup, { once: true });
    document.addEventListener("astro:before-swap", cleanup, { once: true });
  }
</script>
  