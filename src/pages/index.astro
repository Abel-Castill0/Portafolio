---
import BaseLayout from "../layouts/BaseLayout.astro";
import WebGLScene from "../components/WebGLScene.astro";
import ProjectRow from "../components/ProjectRow.astro";
import StackMarquee from "../components/StackMarquee.astro";
import Certificates from "../components/Certificates.astro";
import ContactForm from "../components/ContactForm.astro";
import SocialRail from "../components/SocialRail.astro";

const base = import.meta.env.BASE_URL;
const projects = [
  { index: "01", title: "DPP Control", description: "Operación, caja y reportes convertidos en una interfaz de decisión.", stack: "Next.js · TypeScript · PostgreSQL", href: "https://dpp-pink.vercel.app/login", image: `${base}img/project-dpp.svg` },
  { index: "02", title: "TalentLens", description: "Inteligencia aplicada al análisis de talento y pipelines de selección.", stack: "React · FastAPI · IA", href: "https://talentlens-nu.vercel.app", image: `${base}img/project-talentlens.svg` },
  { index: "03", title: "Avila Parfums", description: "Catálogo sensorial diseñado para acelerar descubrimiento y compra.", stack: "HTML · CSS · JavaScript", href: "https://www.avilaparfums.com", image: `${base}img/avilaparfums.png` },
  { index: "04", title: "Dual Ingeniería", description: "Presencia técnica y captación comercial para ingeniería eléctrica.", stack: "PHP · MySQL · JavaScript", href: "https://abel-castill0.github.io/dual-ingenieria/", image: `${base}img/DualIngenieria.png` },
  { index: "05", title: "App de Gym", description: "Gestión de membresías, rutinas y seguimiento operativo para centros deportivos.", stack: "React · Node.js · MongoDB", href: "https://gimnasio-murex.vercel.app", image: `${base}img/GYM.webp` },
  { index: "06", title: "MOVA", description: "Experiencia móvil enfocada en movimiento, hábitos y progreso personal.", stack: "React Native · Expo · JavaScript" },
  { index: "07", title: "E-commerce Perfumes", description: "Catálogo, recomendación y checkout conversacional para venta de fragancias.", stack: "JavaScript · CSS · WhatsApp API", href: "https://jnafragance.com" },
  { index: "08", title: "App Gestión Pastelería", description: "Pedidos, producción, inventario y control comercial en un flujo unificado.", stack: "Java · Spring Boot · SQL · React" },
  { index: "09", title: "Intranet Tienda Ropa", description: "Operación interna para productos, ventas, usuarios y trazabilidad de stock.", stack: "PHP · SQL · Bootstrap · JavaScript" },
];
---

<BaseLayout title="Abel Castillo — Sistemas digitales con criterio" description="Portafolio de Abel Castillo: desarrollo web, sistemas internos, automatización e inteligencia aplicada.">
  <WebGLScene />
  <SocialRail />
  <header class="site-header">
    <a class="brand" href="#inicio" aria-label="Abel Castillo, inicio">AC<span>®</span></a>
    <nav aria-label="Principal">
      <a href="#trabajo">Trabajo</a>
      <a href="#stack">Stack</a>
      <a href="#perfil">Perfil</a>
      <a class="nav-cta" href="#contacto">Conversemos</a>
    </nav>
  </header>

  <main id="contenido">
    <section class="hero" id="inicio">
      <p class="availability">Disponible para proyectos selectos · Lima, PE</p>
      <h1>
        Sistemas que<br />
        <span>mueven negocios.</span>
      </h1>
      <div class="hero-foot">
        <p>Ingeniería industrial, código y diseño interactivo para convertir procesos complejos en productos digitales claros.</p>
        <a href="#trabajo">Explorar trabajo ↓</a>
      </div>
    </section>

    <section class="work" id="trabajo">
      <div class="section-intro" data-reveal>
        <h2>Trabajo<br />seleccionado</h2>
        <p>Productos reales. Problemas reales. Menos espectáculo gratuito; más sistemas que funcionan.</p>
      </div>
      <div class="project-list">
        {projects.map((project) => <ProjectRow {...project} />)}
      </div>
    </section>

    <StackMarquee />

    <section class="profile" id="perfil">
      <div class="profile-heading">
        <div>
          <p data-reveal>Perfil / 2026</p>
          <h2 data-reveal>Diseño la interfaz.<br />Entiendo el proceso.<br /><span>Construyo el sistema.</span></h2>
        </div>
        <img src={`${base}img/portrait-abel.webp`} width="1800" height="2400" loading="lazy" alt="Retrato de Abel Castillo" data-reveal />
      </div>
      <div class="profile-grid" data-reveal>
        <div class="profile-copy">
          <p>Desarrollador Fullstack con pensamiento de ingeniería: convierto procesos ambiguos en productos digitales claros, mantenibles y preparados para crecer.</p>
          <p>Trabajo de extremo a extremo —arquitectura, interfaces, APIs, datos y despliegue— integrando IA cuando aporta una ventaja real, no como adorno.</p>
          <p>Aplico metodologías ágiles, iteración basada en evidencia y estándares de calidad para entregar soluciones escalables que conectan negocio, tecnología y experiencia.</p>
        </div>
        <ul>
          <li>Frontend / Backend</li>
          <li>Producto / Procesos</li>
          <li>Datos / IA aplicada</li>
          <li>UI / Motion systems</li>
        </ul>
      </div>
    </section>

    <Certificates />

    <section class="contact" id="contacto" data-webgl-zone>
      <div class="contact-heading" data-reveal>
        <p>¿Tienes un proceso roto o una idea ambiciosa?</p>
        <h2>Hagámoslo<br /><span>inevitable.</span></h2>
      </div>
      <ContactForm />
    </section>
  </main>

  <footer>
    <span>© {new Date().getFullYear()} Abel Castillo</span>
    <a href="https://github.com/Abel-Castill0" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
  </footer>

  <script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
      gsap.registerPlugin(ScrollTrigger);
      const controller = new AbortController();
      const context = gsap.context(() => {
        ScrollTrigger.create({
          start: 0,
          end: "max",
          onUpdate: ({ progress }) => dispatchEvent(new CustomEvent("webgl:progress", { detail: { progress } })),
        });

        gsap.utils.toArray<HTMLElement>("[data-reveal]").forEach((element) => {
          gsap.from(element, {
            y: 48,
            opacity: 0,
            duration: 0.9,
            ease: "power4.out",
            scrollTrigger: { trigger: element, start: "top 88%", once: true },
          });
        });

        document.querySelectorAll<HTMLElement>("[data-webgl-zone]").forEach((zone) => {
          ScrollTrigger.create({
            trigger: zone,
            start: "top 70%",
            end: "bottom 30%",
            onToggle: ({ isActive }) => dispatchEvent(new CustomEvent("webgl:focus", { detail: { active: isActive } })),
          });
        });
      });

      document.querySelectorAll<HTMLElement>(".project-row").forEach((row) => {
        const focus = (active: boolean) => dispatchEvent(new CustomEvent("webgl:focus", { detail: { active } }));
        row.addEventListener("pointerenter", () => focus(true), { signal: controller.signal });
        row.addEventListener("pointerleave", () => focus(false), { signal: controller.signal });
        row.addEventListener("focusin", () => focus(true), { signal: controller.signal });
        row.addEventListener("focusout", () => focus(false), { signal: controller.signal });
      });

      const cleanup = () => {
        controller.abort();
        context.revert();
      };
      addEventListener("pagehide", cleanup, { once: true });
      document.addEventListener("astro:before-swap", cleanup, { once: true });
    }
  </script>
</BaseLayout>
